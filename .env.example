# 🌐 Application Configuration
APP_PORT=3000
APP_ENV=development # Options: development, production, test
APP_URL=http://localhost:${APP_PORT}

# 🔑 JWT Authentication
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=3600s              # 1 hour
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d          # 7 days

# 🗄️ Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_db_password
DB_DATABASE=meta_database          # The meta database name

# 🚦 Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_CACHE_TTL=3600               # Cache timeout in seconds (e.g., 1 hour)

# ☁️ AWS Configuration
AWS_REGION=us-west-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
ECR_REPOSITORY=your_ecr_repository_url

# 📧 Email Service (Optional)
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your_email_username
SMTP_PASS=your_email_password
SMTP_FROM=noreply@yourdomain.com

# 🧑‍💻 Development
LOG_LEVEL=debug                    # Log levels: error, warn, info, debug
